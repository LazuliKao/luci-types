{
  "name": "@lazulikao/luci-types",
  "version": "0.1.0",
  "description": "TypeScript type definitions for LuCI (OpenWrt web framework)",
  "type": "module",
  "keywords": [
    "luci",
    "openwrt",
    "typescript",
    "types"
  ],
  "author": "lazulikao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lazulikao/luci-types.git"
  },
  "types": "index.d.ts",
  "bin": {
    "luci-types": "./bin/luci-types.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "import": "./src/i18n/index.ts"
    },
    "./jsx-runtime": {
      "types": "./src/jsx/jsx-runtime.ts",
      "import": "./src/jsx/jsx-runtime.ts",
      "default": "./src/jsx/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx/jsx-dev-runtime.ts",
      "import": "./src/jsx/jsx-dev-runtime.ts",
      "default": "./src/jsx/jsx-dev-runtime.ts"
    },
    "./jsx-factory": {
      "types": "./src/jsx/jsx-factory.ts",
      "import": "./src/jsx/jsx-factory.ts",
      "default": "./src/jsx/jsx-factory.ts"
    }
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "files": [
    "index.d.ts",
    "bin/",
    "luci.d.ts",
    "luci/",
    "jsx.d.ts",
    "src/"
  ],
  "scripts": {
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "tsx": "^4.22.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.0"
  },
  "volta": {
    "node": "25.9.0"
  }
}